# Local environment variables for CoderzClub
# Do not commit real secrets. Copy this file to `.env` and update values.

# MongoDB connection override (optional)
# MONGODB_URI=mongodb+srv://user:pass@cluster.example.net/dbname?retryWrites=true&w=majority

# Judge0 API key (required for code execution)
# This value is loaded into Spring Boot as judge0.api.key via application.properties.
# Set this in a backend-only environment or root .env file.
# Do not use frontend Vite env vars like VITE_JUDGE0_API_KEY for this key.
JUDGE0_API_KEY=your-judge0-api-key

# Local development: allow submission limits to continue without Redis.
SUBMISSION_LIMIT_REDIS_FAIL_OPEN=true

# Redis configuration for submission limits
# SPRING_REDIS_HOST=localhost
# SPRING_REDIS_PORT=6379
# SPRING_REDIS_PASSWORD=

# Email configuration (optional)
# SPRING_MAIL_HOST=smtp.gmail.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=your.email@gmail.com
# SPRING_MAIL_PASSWORD=your-app-password
# APP_EMAIL_FROM=your.email@gmail.com
# APP_BACKEND_URL=http://localhost:8080
